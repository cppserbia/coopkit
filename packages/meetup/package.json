{
  "name": "@coopkit/meetup",
  "version": "0.1.1",
  "description": "Create Meetup.com Draft events from Markdown files in a Git repo. Library + CLI for the coopkit toolkit.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cppserbia/coopkit.git",
    "directory": "packages/meetup"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "coopkit-meetup": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@coopkit/core": "workspace:*",
    "citty": "^0.1.6",
    "gray-matter": "^4.0.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
