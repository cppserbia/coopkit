{
  "name": "@coopkit/core",
  "version": "0.1.0",
  "description": "Shared types for the coopkit toolkit: NormalizedEvent (platform-neutral input for automation packages) and EventFrontmatter (file-on-disk shape).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cppserbia/coopkit.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src", "!src/**/*.test.ts", "README.md"],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src"
  },
  "publishConfig": {
    "access": "public"
  }
}
