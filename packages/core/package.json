{
  "name": "@coopkit/core",
  "version": "0.1.0",
  "description": "Shared types for the coopkit toolkit: NormalizedEvent (platform-neutral input for automation packages) and EventFrontmatter (file-on-disk shape).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cppserbia/coopkit.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "prepack": "bun run build"
  },
  "publishConfig": {
    "access": "public"
  }
}
