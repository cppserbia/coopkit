{
  "name": "coopkit",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source toolkit for community event automation — Meetup drafts, banner generation, social media posts. Markdown-in-Git as source of truth.",
  "license": "MIT",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.14",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.13"
}
